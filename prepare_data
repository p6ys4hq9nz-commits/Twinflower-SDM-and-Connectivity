points(
  tf_occs_raw,
  col = adjustcolor("orange", alpha.f = 0.75),
  bg = adjustcolor("orange", alpha.f = 0.75),
  pch = 21,
  cex = 0.65,
  lwd = 0.25
)

# Scale bar
usr <- par("usr")
bar_len <- 100000
x0 <- usr[1] + 0.16 * diff(usr[1:2])
y0 <- usr[3] + 0.06 * diff(usr[3:4])

segments(x0, y0, x0 + bar_len, y0, lwd = 3)
segments(x0, y0 - 3000, x0, y0 + 3000, lwd = 2)
segments(x0 + bar_len, y0 - 3000, x0 + bar_len, y0 + 3000, lwd = 2)

text(x0 + bar_len / 2, y0 + 9000, "100 km", cex = cex_ticks)


mtext(
  "Coniferous woodland cover",
  side = 4,
  line = 3.8,
  cex = cex_ticks
)

# Legend panel -----------------------------------------------------------------
par(mar = c(0, 0, 0, 0), xpd = TRUE)
plot.new()

legend(
  "center",
  legend = c("Wild occurrences", "Translocations"),
  pch = c(21, 24),
  pt.bg = c(
    adjustcolor("orange", alpha.f = 0.75),
    adjustcolor("red", alpha.f = 0.85)
  ),
  col = c(
    adjustcolor("orange", alpha.f = 0.75),
    adjustcolor("red", alpha.f = 0.85)
  ),
  pt.cex = c(1.2, 1.4),
  horiz = TRUE,
  bty = "n",
  title = "Site type",
  cex = cex_legend,
  title.cex = cex_axis
