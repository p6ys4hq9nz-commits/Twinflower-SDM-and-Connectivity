  "tpi_medium",
  "tpi_large"
)

writeRaster(
  topo_predictors,
  file.path(clim_clean_dir, "topo_preds", paste0(names(topo_predictors), ".tif")),
  overwrite = TRUE
)


#------------------------------------------------------------------------------#
###                   Downscale climate variables to 50 m                   ###
#------------------------------------------------------------------------------#

terraOptions(tempdir = file.path(base_dir, "temp/clim_ds"))

# Load 50 m topography ---------------------------------------------------------
topo_50m_stack <- rast(c(
  file.path(clim_clean_dir, "topo_preds/elevation.tif"),
  file.path(clim_clean_dir, "topo_preds/slope.tif"),
  file.path(clim_clean_dir, "topo_preds/northness.tif"),
  file.path(clim_clean_dir, "topo_preds/eastness.tif")
))
names(topo_50m_stack) <- c("elevation", "slope", "northness", "eastness")

# Aggregate topography to 1 km to match climate resolution.
topo_1km_stack <- aggregate(topo_50m_stack, fact = 20, fun = mean)

# Load current climate variables used to fit downscaling models.
current_files <- list.files(
  file.path(clim_pred_dir, "current"),
  pattern = "\\.tif$",
  full.names = TRUE
)
current_files <- current_files[
  grepl("annual_mean_temp|perc01_temp_coldest|perc09_temp_hottest", current_files)
]

current_stack <- rast(current_files)
names(current_stack) <- c("annual_mean_temp", "perc01_temp_coldest", "perc09_temp_hottest")

# Fit regression models --------------------------------------------------------
models <- list()

for (i in seq_len(nlyr(current_stack))) {
  cat("Fitting model for:", names(current_stack)[i], "\n")
  
  clim <- current_stack[[i]]
  topo_1km_aligned <- resample(topo_1km_stack, clim, method = "bilinear")
  
  df <- spatSample(c(clim, topo_1km_aligned), size = 20000, method = "random", na.rm = TRUE)
  colnames(df) <- c("clim", "elevation", "slope", "northness", "eastness")
  
  models[[names(current_stack)[i]]] <- lm(
    clim ~ elevation + slope + northness + eastness,
    data = df
  )
}

# Clamp 50 m predictors to the range used for model fitting.
mins <- global(topo_1km_stack, "min", na.rm = TRUE)
maxs <- global(topo_1km_stack, "max", na.rm = TRUE)

for (period in c("current", "rcp45", "rcp85")) {
  cat("Processing:", period, "\n")
  
  files <- list.files(
    file.path(clim_pred_dir, period),
    pattern = "\\.tif$",
    full.names = TRUE
  )
  files <- files[grepl("annual_mean_temp|perc01_temp_coldest|perc09_temp_hottest", files)]
  
  clim_stack <- rast(files)
  names(clim_stack) <- c("annual_mean_temp", "perc01_temp_coldest", "perc09_temp_hottest")
  
  downscaled_stack <- NULL
  
  for (i in seq_len(nlyr(clim_stack))) {
    varname <- names(clim_stack)[i]
    cat("Downscaling:", varname, "\n")
    
    clim_1km <- clim_stack[[i]]
    model <- models[[varname]]
    
    topo_50m_clamped <- topo_50m_stack
    for (j in seq_len(nlyr(topo_50m_stack))) {
      topo_50m_clamped[[j]] <- clamp(topo_50m_stack[[j]], mins[j, 1], maxs[j, 1])
    }
    
    # Predict 50 m climate anomaly from topography, then add it to the coarse
    # climate surface so broad-scale climate patterns are retained.
    pred_50m <- predict(topo_50m_clamped, model)
    pred_50m_mean <- aggregate(pred_50m, fact = 20, fun = mean)
    pred_50m_mean_resampled <- resample(pred_50m_mean, pred_50m, method = "bilinear")
    pred_50m_anomaly <- pred_50m - pred_50m_mean_resampled
    
    clim_1km_resampled <- resample(clim_1km, pred_50m, method = "bilinear")
    final <- clim_1km_resampled + pred_50m_anomaly
    
    downscaled_stack <- if (is.null(downscaled_stack)) final else c(downscaled_stack, final)
  }
  
  names(downscaled_stack) <- names(clim_stack)
  
  out_dir <- file.path(base_dir, "temp/clim_ds", period)
  dir.create(out_dir, recursive = TRUE, showWarnings = FALSE)
  
  writeRaster(
    downscaled_stack,
    file.path(out_dir, paste0(names(downscaled_stack), ".tif")),
    overwrite = TRUE
  )
}


#------------------------------------------------------------------------------#
###          Add downscaled predictors back to climate stacks                ###
#------------------------------------------------------------------------------#

periods <- c("current", "rcp45", "rcp85")
down_dir <- file.path(base_dir, "temp/clim_ds")
clim_stacks_list <- list()

for (p in periods) {
  clim_files <- list.files(file.path(clim_pred_dir, p), pattern = "\\.tif$", full.names = TRUE)
  clim_stack <- rast(clim_files)
  
  names(clim_stack) <- tools::file_path_sans_ext(basename(clim_files))
  names(clim_stack) <- sub(paste0("^", p, "_"), "", names(clim_stack))
  
  down_files <- list.files(file.path(down_dir, p), pattern = "\\.tif$", full.names = TRUE)
  downscaled <- rast(down_files)
  names(downscaled) <- tools::file_path_sans_ext(basename(down_files))
  
  if (!compareGeom(clim_stack, downscaled, stopOnError = FALSE)) {
    downscaled <- resample(downscaled, clim_stack, method = "bilinear")
  }
  
  to_replace <- intersect(names(clim_stack), names(downscaled))
  cat("Replacing in", p, ":", to_replace, "\n")
  
  if (length(to_replace) > 0) {
    clim_stack[[to_replace]] <- downscaled[[to_replace]]
  }
  
  clim_stacks_list[[p]] <- clim_stack
  
  out_dir <- file.path(clim_pred_dir, paste0(p, "_updated"))
  dir.create(out_dir, recursive = TRUE, showWarnings = FALSE)
  
  for (nm in names(clim_stack)) {
    writeRaster(
      clim_stack[[nm]],
      file.path(out_dir, paste0(nm, ".tif")),
      overwrite = TRUE
    )
  }
  
  cat("Finished:", p, "\n")
}

# Check sources of files to confirm replacement.
sources(clim_stack)
