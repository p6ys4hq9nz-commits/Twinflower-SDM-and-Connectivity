# Process local climate data ---------------------------------------------------
rainfall_threshold <- 1 # mm; used to calculate dry spell duration.

for (period in c("current", "rcp45", "rcp85")) {
  
  cat("Processing climate period:", period, "\n")
  
  period_masked_dir <- file.path(clim_clean_dir, paste0(period, "_masked"))
  
  if (period == "current") {
    temp_files <- list.files(period_masked_dir, pattern = "1km_mon", full.names = TRUE)
    rain_files <- list.files(period_masked_dir, pattern = "1km_day", full.names = TRUE)
    
    years <- sort(unique(str_extract(basename(temp_files), "\\d{4}")))
    start_year <- min(as.numeric(years))
    end_year   <- max(as.numeric(years))
    
    temp_stack <- rast(temp_files)
    names(temp_stack) <- sprintf("%d%02d", rep(start_year:end_year, each = 12), 1:12)
    
  } else {
    start_year <- 2070
    end_year   <- 2073
    
    temp_files <- list.files(
      period_masked_dir,
      pattern = "tas_uk_1km_monthly",
      full.names = TRUE
    )
    rain_files <- list.files(
      period_masked_dir,
      pattern = "pr_uk_1km_daily",
      full.names = TRUE
    )
    
    temp_stack <- rast(temp_files)
    
    # Assign monthly dates because the future scenario rasters do not reliably
    # carry the required time metadata after processing.
    n_layers <- nlyr(temp_stack)
    dates <- seq(as.Date(paste0(start_year, "-01-01")), by = "month", length.out = n_layers)
    time(temp_stack) <- dates
    
    temp_stack <- temp_stack %>% subset(which(year(time(.)) %in% start_year:end_year))
    names(temp_stack) <- sprintf("%d%02d", rep(start_year:end_year, each = 12), 1:12)
    
    # Convert Kelvin to Celsius.
    values(temp_stack) <- values(temp_stack) - 272.15
  }
  
  # Identify hottest and coldest quarters --------------------------------------
  quarters <- ceiling(seq_len(nlyr(temp_stack)) / 3)
  temp_stack_qtr <- tapp(temp_stack, quarters, fun = median)
  avg_qtr_temp <- global(temp_stack_qtr, stat = "median", na.rm = TRUE)
  
  qtr_df <- data.frame(
    q_index = seq_len(nrow(avg_qtr_temp)),
    temp = avg_qtr_temp$mean
  )
  
  qtr_df$year <- start_year + ((qtr_df$q_index - 1) %/% 4)
  qtr_df$qtr  <- (qtr_df$q_index - 1) %% 4 + 1
  
  hottest_qtrs_dates <- qtr_df %>%
    group_by(year) %>%
    slice_max(temp, n = 1, with_ties = FALSE) %>%
    mutate(label = paste0(year, "-Q", qtr)) %>%
    pull(label)
  
  coldest_qtrs_dates <- qtr_df %>%
    group_by(year) %>%
    slice_min(temp, n = 1, with_ties = FALSE) %>%
    mutate(label = paste0(year, "-Q", qtr)) %>%
    pull(label)
  
  # Rainfall and temperature of hottest/coldest quarters -----------------------
  perc09_total_rain_coldest <- get_quarterly_rainfall(
    coldest_qtrs_dates,
    rain_files,
    period
  )
  perc09_total_rain_hottest <- get_quarterly_rainfall(
    hottest_qtrs_dates,
    rain_files,
    period
  )
  
  perc01_temp_coldest <- get_quarterly_temperature(
    coldest_qtrs_dates,
    temp_stack,
    start_year,
    quantile = 0.1
  )
  perc09_temp_hottest <- get_quarterly_temperature(
    hottest_qtrs_dates,
    temp_stack,
    start_year,
    quantile = 0.9
  )
  
  # Longest dry spell during hottest quarter -----------------------------------
  year_files <- list()
  dryspell_rasters <- list()
  
  for (file in rain_files) {
    file_year <- str_extract(basename(file), "\\d{4}")
    year_files[[file_year]] <- c(year_files[[file_year]], file)
  }
  
  for (file_year in names(year_files)) {
    year_stack <- rast(year_files[[file_year]])
    year_stack <- convert_future_rainfall(year_stack, period)
    names(year_stack) <- paste0("day", seq_len(nlyr(year_stack)))
    
    hottest_qtr <- hottest_qtrs_dates[grepl(paste0("^", file_year, "-"), hottest_qtrs_dates)]
    qtr <- as.numeric(sub(".*-Q", "", hottest_qtr))
    
    start_month <- (qtr - 1) * 3 + 1
    end_month   <- start_month + 2
    start_date  <- as.Date(paste(file_year, start_month, "01", sep = "-"))
    end_date    <- as.Date(paste(file_year, end_month + 1, "01", sep = "-")) - 1
    
    days_in_hottest_qtr <- yday(seq.Date(start_date, end_date, by = "day"))
    valid_days <- days_in_hottest_qtr[
      days_in_hottest_qtr >= 1 & days_in_hottest_qtr <= nlyr(year_stack)
    ]
    
    year_stack_hottest <- year_stack[[valid_days]]
    dryspell_rasters[[file_year]] <- calculate_longest_dryspell(
      year_stack_hottest,
      rainfall_threshold
    )
  }
  
  dry_duration_09perc <- app(rast(dryspell_rasters), fun = calc_quantiles)
  
  # Annual temperature mean, SD and range --------------------------------------
  temp_years <- unique(substr(names(temp_stack), 1, 4))
  
  yearly_temp <- tapp(
    temp_stack,
    index = temp_years,
    fun = mean,
    na.rm = TRUE
  )
  
  annual_mean_temp <- mean(yearly_temp, na.rm = TRUE)
  year_sd_temp_list <- list()
  year_temp_range_list <- list()
  
  for (file_year in temp_years) {
    year_temp_stack <- temp_stack[[substr(names(temp_stack), 1, 4) == file_year]]
    
    year_sd_temp_list[[file_year]] <- app(year_temp_stack, fun = sd, na.rm = TRUE)
    year_temp_range_list[[file_year]] <- max(year_temp_stack) - min(year_temp_stack)
  }
  
  mean_year_sd_temp <- mean(rast(year_sd_temp_list))
  mean_year_range_temp <- mean(rast(year_temp_range_list))
  
  clim_stack <- c(
    perc09_total_rain_coldest,
    perc09_total_rain_hottest,
    perc01_temp_coldest,
    perc09_temp_hottest,
    dry_duration_09perc,
    annual_mean_temp,
    mean_year_sd_temp,
    mean_year_range_temp
  )
  
  names(clim_stack) <- paste0(
    period,
    "_",
    c(
      "perc09_total_rain_coldest",
      "perc09_total_rain_hottest",
      "perc01_temp_coldest",
      "perc09_temp_hottest",
      "dry_duration_09perc",
      "annual_mean_temp",
      "annual_sd_temp",
      "temp_seasonality"
    )
  )
  
  # Write final climate raster stack ------------------------------------------
  period_out_dir <- file.path(clim_pred_dir, period)
  dir.create(period_out_dir, recursive = TRUE, showWarnings = FALSE)
  
  writeRaster(
    clim_stack,
    file.path(period_out_dir, paste0(names(clim_stack), ".tif")),
    overwrite = TRUE
  )
}

