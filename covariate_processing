# Crop, mask and export NetCDF climate layers to a ROI.
crop_mask_export_climate <- function(input_dir, output_dir, roi, project_to = roi,
                                     pattern = "\\.nc$") {
  dir.create(output_dir, recursive = TRUE, showWarnings = FALSE)
  
  cov_files <- list.files(
    input_dir,
    pattern = pattern,
    full.names = TRUE,
    recursive = TRUE
  )
  
  print(head(cov_files))
  
  crop_one_file <- function(filepath) {
    img <- rast(filepath) %>%
      terra::project(crs(project_to)) %>%
      crop(roi) %>%
      mask(roi)
    
    # Remove large NoData marker values occasionally present in NetCDF inputs.
    NAflag(img) <- 1e+20
    img[img > 1e10] <- NA
    img[img < -1e10] <- NA
    
    outpath <- file.path(
      output_dir,
      paste0(tools::file_path_sans_ext(basename(filepath)), "_masked.tif")
    )
    
    writeRaster(img, outpath, overwrite = TRUE)
    outpath
  }
  
  invisible(lapply(cov_files, crop_one_file))
}

# Convert future precipitation from kg m-2 s-1 to mm day-1.
convert_future_rainfall <- function(rain_stack, period) {
  if (period != "current") {
    rain_stack[rain_stack > 1e10] <- NA
    values(rain_stack) <- values(rain_stack) * 86400
  }
  rain_stack
}

# Calculate the longest consecutive dry spell for a raster stack of daily rain.
calculate_longest_dryspell <- function(year_stack, threshold) {
  dry_day_count <- terra::init(year_stack[[1]], 0)
  dry_day_count <- mask(dry_day_count, year_stack[[1]])
  max_dry_spell <- dry_day_count
  
  for (i in seq_len(nlyr(year_stack))) {
    is_dry <- year_stack[[i]] < threshold
    dry_day_count <- ifel(is_dry, dry_day_count + 1, 0)
    max_dry_spell <- max(max_dry_spell, dry_day_count)
  }
  
  max_dry_spell
}

# Build quarterly rainfall totals for selected quarter labels, e.g. "2070-Q3".
get_quarterly_rainfall <- function(qtrs_dates, rain_files, period) {
  quarterly_rainfall_rasters <- list()
  
  for (i in seq_along(qtrs_dates)) {
    year_qtr <- strsplit(qtrs_dates[[i]], "-Q")[[1]]
    year <- as.numeric(year_qtr[1])
    qtr  <- as.numeric(year_qtr[2])
    
    q_start <- (qtr - 1) * 3 + 1
    q_end   <- q_start + 2
    q_rainfall_sum <- NULL
    
    for (month in q_start:q_end) {
      month_pattern <- sprintf("%04d%02d", year, month)
      month_rain_files <- rain_files[grep(month_pattern, basename(rain_files))]
      
      if (length(month_rain_files) > 0) {
        month_rain_stack <- rast(month_rain_files)
        month_rain_stack <- convert_future_rainfall(month_rain_stack, period)
        month_rain_sum <- sum(month_rain_stack, na.rm = TRUE)
        
        q_rainfall_sum <- if (is.null(q_rainfall_sum)) {
          month_rain_sum
        } else {
          q_rainfall_sum + month_rain_sum
        }
      }
    }
    
    quarterly_rainfall_rasters[[i]] <- q_rainfall_sum
  }
  
  app(rast(quarterly_rainfall_rasters), fun = calc_quantiles)
}

# Build quarterly temperature summaries for selected quarter labels.
get_quarterly_temperature <- function(qtrs_dates, temp_stack, start_year,
                                      quantile = 0.9) {
  quarterly_temp_rasters <- list()
  
  for (i in seq_along(qtrs_dates)) {
    year_qtr <- strsplit(qtrs_dates[[i]], "-Q")[[1]]
    year <- as.numeric(year_qtr[1])
    qtr  <- as.numeric(year_qtr[2])
    
    q_start <- (qtr - 1) * 3 + 1
    q_end   <- q_start + 2
    month_temp_rasters <- list()
    
    for (month in q_start:q_end) {
      layer_id <- (year - start_year) * 12 + month
      
      if (layer_id > nlyr(temp_stack)) {
        stop(paste("Layer index out of range:", layer_id))
      }
      
      month_temp_rasters[[length(month_temp_rasters) + 1]] <- temp_stack[[layer_id]]
    }
    
    quarterly_temp_rasters[[i]] <- rast(month_temp_rasters) %>% median()
  }
  
  app(rast(quarterly_temp_rasters), fun = calc_quantiles, probs = quantile)
}

# Rasterise, crop, mask and write a soil layer.
process_soil_layer <- function(vector_data, field, template, roi, outpath,
                               make_factor = FALSE) {
  soil_rast <- rasterize(vector_data[, field], template, field = field, touches = TRUE)
  
  if (make_factor) {
    soil_rast <- as.factor(soil_rast)
  }
  
  soil_rast <- crop(soil_rast, template)
  soil_rast <- mask(soil_rast, roi)
  
  writeRaster(soil_rast, outpath, overwrite = TRUE)
  soil_rast
}


