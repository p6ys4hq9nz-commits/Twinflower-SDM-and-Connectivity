plot_partial_effect <- function(model, predictor_name, env_sample, reference_row,
                                n = 100, type = "cloglog") {
  x <- env_sample[[predictor_name]]
  
  grid_vals <- if (is.numeric(x)) {
    seq(min(x, na.rm = TRUE), max(x, na.rm = TRUE), length.out = n)
  } else {
    sort(unique(x[!is.na(x)]))
  }
  
  newdata <- reference_row[rep(1, length(grid_vals)), , drop = FALSE]
  newdata[[predictor_name]] <- grid_vals
  
  if (predictor_name == "soil_type") {
    newdata[[predictor_name]] <- factor(
      newdata[[predictor_name]],
      levels = levels(env_sample[[predictor_name]])
    )
  }
  
  preds <- predict(model, newdata = newdata, type = type)
  
  out <- data.frame(
    predictor = predictor_name,
    predictor_label = label_lookup(predictor_name),
    x = grid_vals,
    y = preds
  )
  
  p <- ggplot(out, aes(x = x, y = y)) +
    geom_line(linewidth = 1.1, colour = "#2C3E50") +
    labs(
      x = label_lookup(predictor_name),
      y = "Predicted suitability",
      title = paste("Partial effect:", label_lookup(predictor_name))
    ) +
    theme_classic(base_size = 14) +
    theme(
      plot.title = element_text(face = "bold"),
      axis.title = element_text(face = "bold")
    )
  
  list(data = out, plot = p)
}

plot_partial_categorical <- function(model, predictor_name, env_sample, reference_row,
                                     type = "cloglog") {
  levs <- levels(droplevels(env_sample[[predictor_name]]))
  
  newdata <- reference_row[rep(1, length(levs)), , drop = FALSE]
  newdata[[predictor_name]] <- factor(levs, levels = levs)
  
  if ("soil_type" %in% names(newdata)) {
    newdata$soil_type <- factor(newdata$soil_type, levels = levs)
  }
  
  preds <- predict(model, newdata = newdata, type = type)
  
  out <- data.frame(
    predictor = predictor_name,
    predictor_label = label_lookup(predictor_name),
    x = factor(levs, levels = levs),
    y = preds
  )
  
  if (predictor_name == "soil_type") {
    soil_ids <- as.numeric(as.character(levs))
    soil_labels_used <- soil_lut[soil_ids + 1]
    out$x <- factor(soil_labels_used, levels = soil_labels_used)
  } else {
    out$x <- factor(out$x, levels = sort(unique(levs)))
  }
  
  p <- ggplot(out, aes(x = x, y = y)) +
    geom_col(fill = "#5F5F5F", width = 0.85) +
    scale_y_continuous(limits = c(0, 0.08), breaks = seq(0, 0.08, by = 0.01)) +
    labs(
      x = label_lookup(predictor_name),
      y = "Predicted suitability",
      title = paste("Partial effects of", label_lookup(predictor_name))
    ) +
    theme_classic(base_size = 14) +
    theme(
      plot.title = element_text(face = "bold", hjust = 0.5),
      axis.title = element_text(face = "bold"),
      axis.text.x = element_text(angle = 45, hjust = 1, size = 8),
      axis.text.y = element_text(size = 8)
    )
  
  list(data = out, plot = p)
}

