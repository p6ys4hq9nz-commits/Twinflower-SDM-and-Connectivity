# Standardise CRS metadata before resampling. This protects the workflow from
# layers with missing or unreadable CRS strings.
fix_layer_crs <- function(layer, template, layer_name = NULL, assume_crs = NULL) {
  
  if (is.null(layer_name) || is.na(layer_name) || layer_name == "") {
    layer_name <- tryCatch(names(layer)[1], error = function(e) "unknown_layer")
    if (is.null(layer_name) || is.na(layer_name) || layer_name == "") {
      layer_name <- "unknown_layer"
    }
  }
  
  layer_crs <- tryCatch(terra::crs(layer), error = function(e) NA_character_)
  
  if (is.na(layer_crs) || !nzchar(layer_crs)) {
    if (is.null(assume_crs) || is.na(assume_crs) || !nzchar(assume_crs)) {
      message("Skipping ", layer_name, ": missing CRS and no assume_crs provided")
      return(NULL)
    }
    
    message("Assigning missing CRS to ", layer_name)
    ok <- tryCatch({
      terra::crs(layer) <- assume_crs
      TRUE
    }, error = function(e) {
      message("Skipping ", layer_name, ": failed to assign CRS - ", e$message)
      FALSE
    })
    
    if (!ok) return(NULL)
  }
  
  crs_ok <- tryCatch({
    terra::same.crs(layer, template)
    TRUE
  }, error = function(e) FALSE)
  
  if (!crs_ok) {
    if (is.null(assume_crs) || is.na(assume_crs) || !nzchar(assume_crs)) {
      message("Skipping ", layer_name, ": unreadable/broken CRS")
      return(NULL)
    }
    
    message("Replacing broken CRS for ", layer_name)
    ok <- tryCatch({
      terra::crs(layer) <- assume_crs
      TRUE
    }, error = function(e) {
      message("Skipping ", layer_name, ": failed to replace broken CRS - ", e$message)
      FALSE
    })
    
    if (!ok) return(NULL)
  }
  
  final_ok <- tryCatch({
    x <- terra::crs(layer)
    !is.na(x) && nzchar(x)
  }, error = function(e) FALSE)
  
  if (!final_ok) {
    message("Skipping ", layer_name, ": CRS invalid after cleanup")
    return(NULL)
  }
  
  layer
}

# Align, mask and write all predictor layers for a scenario. Existing valid
# files are reused to avoid unnecessary reprocessing.
resample_and_write <- function(predictors, template, ROI, outdir,
                               categorical_layers = c("soil_type")) {
  
  dir.create(outdir, showWarnings = FALSE, recursive = TRUE)
  
  all_layers <- list()
  for (p in predictors) {
    for (i in seq_len(nlyr(p))) {
      all_layers[[length(all_layers) + 1]] <- p[[i]]
    }
  }
  
  out_files <- c()
  
  for (i in seq_along(all_layers)) {
    layer <- all_layers[[i]]
    layer_name <- names(layer)[1]
    if (is.null(layer_name) || layer_name == "") layer_name <- paste0("layer_", i)
    
    outfile <- file.path(outdir, paste0(layer_name, ".tif"))
    
    if (file.exists(outfile)) {
      valid <- TRUE
      r <- try(terra::rast(outfile), silent = TRUE)
      
      if (inherits(r, "try-error")) {
        valid <- FALSE
      } else {
        vals <- try(terra::global(r, "notNA", na.rm = TRUE), silent = TRUE)
        if (inherits(vals, "try-error") || vals[1, 1] == 0) valid <- FALSE
        rm(r)
      }
      
      if (valid) {
        message("Skipping valid existing: ", layer_name)
        out_files <- c(out_files, outfile)
        next
      }
      
      message("Reprocessing corrupted file: ", layer_name)
      file.remove(outfile)
    }
    
    message("Processing: ", layer_name)
    
    method <- if (layer_name %in% categorical_layers) "near" else "bilinear"
    datatype <- if (layer_name %in% categorical_layers) "INT2S" else "FLT4S"
    
    layer <- fix_layer_crs(
      layer = layer,
      template = template,
      layer_name = layer_name,
      assume_crs = terra::crs(template)
    )
    if (is.null(layer)) next
    
    if (!terra::same.crs(layer, template)) {
      layer <- try(terra::project(layer, terra::crs(template)), silent = TRUE)
      if (inherits(layer, "try-error")) {
        message("Projection failed: ", layer_name)
        next
      }
    }
    
    layer <- try(terra::resample(layer, template, method = method), silent = TRUE)
    if (inherits(layer, "try-error")) {
      message("Resample failed: ", layer_name)
      next
    }
    
    layer <- try(terra::mask(terra::crop(layer, ROI), ROI), silent = TRUE)
    if (inherits(layer, "try-error")) {
      message("Mask failed: ", layer_name)
      next
    }
    
    rng <- try(terra::global(layer, c("min", "max"), na.rm = TRUE), silent = TRUE)
    if (inherits(rng, "try-error") || all(is.na(rng))) {
      message("Skipping empty layer: ", layer_name)
      next
    }
    
    success <- try(
      terra::writeRaster(
        layer,
        filename = outfile,
        overwrite = TRUE,
        wopt = list(gdal = c("COMPRESS=LZW"), datatype = datatype)
      ),
      silent = TRUE
    )
    
    if (inherits(success, "try-error") || !file.exists(outfile)) {
      message("Write failed: ", layer_name)
      next
    }
    
    out_files <- c(out_files, outfile)
    rm(layer)
    gc()
  }
  
  if (length(out_files) == 0) stop("No rasters were successfully written.")
  
  message("Building final stack...")
  terra::rast(out_files)
}

# Select the best ENMeval model using the same multi-criteria rules as the
# original script: ΔAICc, omission, AUC difference, then validation AUC.
select_best_model <- function(enmeval_object) {
  results_tbl <- enmeval_object@results
  cand <- results_tbl
  
  if ("delta.AICc" %in% names(cand) && any(!is.na(cand$delta.AICc))) {
    cand <- cand[cand$delta.AICc <= 2, , drop = FALSE]
    if (nrow(cand) == 0) {
      cand <- results_tbl[which.min(results_tbl$delta.AICc), , drop = FALSE]
    }
  }
  
  if ("or.10p.avg" %in% names(cand)) {
    min_or <- min(cand$or.10p.avg, na.rm = TRUE)
    cand <- cand[cand$or.10p.avg == min_or, , drop = FALSE]
  }
  
  if ("auc.diff.avg" %in% names(cand)) {
    min_aucdiff <- min(cand$auc.diff.avg, na.rm = TRUE)
    cand <- cand[cand$auc.diff.avg == min_aucdiff, , drop = FALSE]
  }
  
  best_row <- if ("auc.val.avg" %in% names(cand)) {
    cand[which.max(cand$auc.val.avg), , drop = FALSE]
  } else {
    cand[1, , drop = FALSE]
  }
  
  best_idx <- as.integer(rownames(best_row))
  
  list(
    best_idx = best_idx,
    best_row = best_row,
    best_model = enmeval_object@models[[best_idx]],
    results_tbl = results_tbl
  )
}

# Extract raw predictor names needed by a maxnet model, including predictors
# used inside hinge/quadratic/categorical terms.
get_raw_model_vars <- function(model) {
  model_vars <- names(model$betas)
  model_vars <- model_vars[model_vars != "(Intercept)"]
  
  unique(c(
    model_vars[!grepl("^I\\(|^categorical\\(", model_vars)],
    gsub("^I\\((.+)\\^2\\)$", "\\1", model_vars[grepl("^I\\(.+\\^2\\)$", model_vars)]),
    gsub(
      "^categorical\\((.+)\\):.*$",
      "\\1",
      model_vars[grepl("^categorical\\(.+\\):", model_vars)]
    )
  ))
}

check_vars <- function(r, vars, nm) {
  miss <- setdiff(vars, names(r))
  if (length(miss) > 0) {
    stop(sprintf("Missing predictors in %s: %s", nm, paste(miss, collapse = ", ")))
  }
}

# Prediction wrapper for terra::predict. Converts NaN to NA and only predicts
# complete rows, preventing failures caused by missing raster cells.
predfun_cloglog <- function(model, data) {
  data <- as.data.frame(data)
  
  for (j in seq_along(data)) {
    x <- data[[j]]
    x[is.nan(x)] <- NA
    data[[j]] <- x
  }
  
  ok <- stats::complete.cases(data)
  out <- rep(NA_real_, nrow(data))
  
  if (any(ok)) {
    out[ok] <- as.numeric(predict(model, data[ok, , drop = FALSE], type = "cloglog"))
  }
  
  out
}

