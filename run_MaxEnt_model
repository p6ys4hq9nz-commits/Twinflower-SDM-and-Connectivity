# Paginated plotting helper for informative/flat continuous predictors.
plot_paginated_partial_effects <- function(predictors, partial_df_cont, label_fun,
                                           filename_prefix, colour, free_scales = "free") {
  if (length(predictors) == 0) return(invisible(NULL))
  
  ncol_fixed <- 3
  nrow_fixed <- 3
  n_pages <- ceiling(length(predictors) / (ncol_fixed * nrow_fixed))
  
  for (i in seq_len(n_pages)) {
    plot_df <- partial_df_cont[partial_df_cont$predictor %in% predictors, ]
    plot_df$predictor_label <- factor(plot_df$predictor_label, levels = label_fun(predictors))
    
    p <- ggplot(plot_df, aes(x = x, y = y, group = 1)) +
      geom_line(linewidth = 1.1, colour = colour) +
      ggforce::facet_wrap_paginate(
        ~ predictor_label,
        ncol = ncol_fixed,
        nrow = nrow_fixed,
        page = i,
        scales = free_scales
      ) +
      labs(x = "Predictor value", y = "Predicted suitability") +
      theme_classic(base_size = 14) +
      theme(
        strip.text = element_text(face = "bold", size = 11),
        axis.title = element_text(face = "bold"),
        panel.spacing = unit(0.8, "lines"),
        aspect.ratio = 1
      )
    
    if (filename_prefix == "partial_effects_flat_page_") {
      p <- p + scale_y_continuous(limits = range(partial_df_cont$y, na.rm = TRUE))
    }
    
    print(p)
    
    ggsave(
      filename = file.path(partial_dir, paste0(filename_prefix, i, ".png")),
      plot = p,
      width = 12,
      height = 12,
      dpi = 300
    )
  }
}

