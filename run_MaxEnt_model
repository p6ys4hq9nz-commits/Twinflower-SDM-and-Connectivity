effect_strength <- aggregate(
  y ~ predictor,
  data = partial_df_cont,
  FUN = function(x) {
    diffs <- diff(x)
    max_change <- max(abs(diffs), na.rm = TRUE)
    total_range <- max(x, na.rm = TRUE) - min(x, na.rm = TRUE)
    c(max_slope = max_change, range = total_range)
  }
)

