crop_mask_roi <- function(x, roi) {
  crop(x, roi, mask = TRUE)
}

# Standardise a raster to 0–1. Constant rasters are returned as zero surfaces.
scale01_raster <- function(r) {
  rng <- global(r, c("min", "max"), na.rm = TRUE)
  rmin <- rng[1, "min"]
  rmax <- rng[1, "max"]
  
  if (!is.finite(rmin) || !is.finite(rmax)) {
    stop("Raster has no finite values.")
  }
  
  if (isTRUE(all.equal(rmin, rmax))) {
    return(r * 0)
  }
  
  (r - rmin) / (rmax - rmin)
}

# Standardise a vector to 0–1. Used for patch ranking metrics.
scale01_vector <- function(x) {
  if (all(is.na(x))) return(rep(NA_real_, length(x)))
  
  rng <- range(x, na.rm = TRUE)
  if (isTRUE(all.equal(rng[1], rng[2]))) return(rep(0, length(x)))
  
  (x - rng[1]) / (rng[2] - rng[1])
}

# Draw a vertical colour bar in a dedicated plotting panel.
draw_vertical_legend <- function(cols, zlim, title,
                                 axis_side = 4,
                                 bar_x = c(0.7, 0.9),
                                 title_line = 0.2,
                                 cex.axis = 0.9,
                                 cex.title = 0.6) {
  n <- length(cols)
  
  par(mar = c(2, 2, 2, 2))
  plot.new()
  plot.window(xlim = c(0, 1), ylim = zlim, xaxs = "i", yaxs = "i")
  
  ybreaks <- seq(zlim[1], zlim[2], length.out = n + 1)
  
  for (i in seq_len(n)) {
    rect(
      xleft   = bar_x[1],
      ybottom = ybreaks[i],
      xright  = bar_x[2],
      ytop    = ybreaks[i + 1],
      col     = cols[i],
      border  = NA
    )
  }
  
  at_vals <- pretty(zlim, n = 8)
  
  axis(
    axis_side,
    at = at_vals,
    labels = format(round(at_vals, 2), trim = TRUE),
    las = 1,
    cex.axis = cex.axis,
    lwd = 0.8,
    lwd.ticks = 0.8
  )
  
  mtext(title, side = 3, line = title_line, cex = cex.title)
}

