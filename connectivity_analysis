# Reproject and crop nodes to match suitability raster.
tf_occs <- project(tf_occs_precise, crs(current_scot)) |> crop(ROI)
translocs <- project(translocs_raw, crs(current_scot)) |> crop(ROI)

tf_occs_precise <- tf_occs
translocs_precise <- translocs

# 200 m threshold is used for local connectivity, representing maximum seed
# dispersal distance.
max_dist_m <- 200

# Add node metadata before combining wild and translocated sites.
tf_occs_precise$node_type   <- "wild"
translocs_precise$node_type <- "translocated"

tf_occs_precise$node_id   <- paste0("W_", seq_len(nrow(tf_occs_precise)))
translocs_precise$node_id <- paste0("T_", seq_len(nrow(translocs_precise)))

node_candidates <- rbind(tf_occs_precise, translocs_precise)

# Deduplicate nodes by suitability raster cell. Wild nodes take priority if a
# wild and translocated point fall in the same cell.
node_candidates$cell_id <- cellFromXY(current_scot, crds(node_candidates))
node_candidates <- node_candidates[!is.na(node_candidates$cell_id), ]

node_df <- as.data.frame(node_candidates, geom = "XY") %>%
  mutate(node_priority = if_else(node_type == "wild", 1, 2)) %>%
  arrange(cell_id, node_priority) %>%
  distinct(cell_id, .keep_all = TRUE)

patches <- vect(node_df, geom = c("x", "y"), crs = crs(current_scot))

# Mean suitability across current and future scenarios acts as a simple climate
# stability surface.
climate_stability <- app(c(current_scot, rcp45_scot, rcp85_scot), fun = mean)

# Convert current suitability to resistance. High suitability = low resistance.
resistance <- (1 - current_scot)^2
resistance <- clamp(resistance, lower = 0.001, upper = 1, values = TRUE)
resistance <- crop_mask_roi(resistance, ROI)

res_raster <- raster(resistance)
conductance <- 1 / res_raster

tr <- transition(conductance, transitionFunction = mean, directions = 8)
tr <- geoCorrection(tr, type = "c")

# Habitat and climate components are weighted equally for the initial priority
# surface. Connectivity and area are added later at patch level.
current_std   <- scale01_raster(current_scot)
stability_std <- scale01_raster(climate_stability)
priority_surface <- 0.5 * current_std + 0.5 * stability_std


#------------------------------------------------------------------------------#
###              Candidate patch generation and summarisation                ###
#------------------------------------------------------------------------------#

# Convert the top 1% of priority raster cells into candidate polygons.
vals <- values(priority_surface, mat = FALSE, na.rm = TRUE)
thr <- unname(quantile(vals, probs = 0.99, na.rm = TRUE))

cat("Threshold =", thr, "\n")
print(global(priority_surface, c("min", "max", "mean"), na.rm = TRUE))

high_priority <- ifel(priority_surface >= thr, 1, NA)
n_high <- global(!is.na(high_priority), "sum", na.rm = TRUE)[1, 1]

cat("Number of high-priority cells =", n_high, "\n")
plot(high_priority, main = "High-priority cells")

if (is.na(n_high) || n_high == 0) {
  stop("No high-priority raster cells survived the relative threshold. Try lowering the quantile, e.g. 0.80 or 0.75.")
}

candidate_patches <- as.polygons(high_priority, dissolve = TRUE, na.rm = TRUE)
candidate_patches <- candidate_patches[expanse(candidate_patches) > 0, ]
candidate_patches$candidate_id <- paste0("C_", seq_len(nrow(candidate_patches)))

if (nrow(candidate_patches) == 0) {
  stop("High-priority cells exist, but no candidate polygons were created. Check polygon conversion and area filtering.")
}

# Extract habitat/climate summaries for each candidate patch.
current_extract   <- terra::extract(current_std, candidate_patches, fun = mean, na.rm = TRUE)
stability_extract <- terra::extract(stability_std, candidate_patches, fun = mean, na.rm = TRUE)
priority_extract  <- terra::extract(priority_surface, candidate_patches, fun = mean, na.rm = TRUE)

candidate_patches$mean_current_suitability <- current_extract[, 2]
candidate_patches$mean_climate_stability   <- stability_extract[, 2]
candidate_patches$mean_priority            <- priority_extract[, 2]
candidate_patches$area_m2 <- expanse(candidate_patches, unit = "m")
candidate_patches$area_ha <- candidate_patches$area_m2 / 10000

# Remove candidate patches with low mean current suitability.
candidate_patches <- candidate_patches[candidate_patches$mean_current_suitability >= 0.5, ]
candidate_patches$candidate_id <- paste0("C_", seq_len(nrow(candidate_patches)))

# Centroids are used only as representative points for distance/cost calculations.
candidate_pts <- centroids(candidate_patches)

candidate_metrics <- calculate_candidate_connectivity(
  candidate_pts = candidate_pts,
  candidate_patches = candidate_patches,
  patches = patches,
  transition_layer = tr,
  max_dist_m = max_dist_m
)

candidate_patch_table <- as.data.frame(candidate_patches) %>%
  left_join(candidate_metrics, by = "candidate_id")


#------------------------------------------------------------------------------#
###                         Candidate ranking                                ###
#------------------------------------------------------------------------------#

candidate_patch_table$current_score    <- scale01_vector(candidate_patch_table$mean_current_suitability)
candidate_patch_table$stability_score  <- scale01_vector(candidate_patch_table$mean_climate_stability)
candidate_patch_table$area_score       <- scale01_vector(candidate_patch_table$area_ha)
candidate_patch_table$wild_count_score <- scale01_vector(candidate_patch_table$n_wild_200m)
candidate_patch_table$node_count_score <- scale01_vector(candidate_patch_table$n_nodes_200m)

# Lower cost to wild nodes is better, so invert the standardised cost.
candidate_patch_table$cost_score <- ifelse(
  is.na(candidate_patch_table$min_cost_to_wild),
  NA_real_,
  1 - scale01_vector(candidate_patch_table$min_cost_to_wild)
)
candidate_patch_table$cost_score[is.na(candidate_patch_table$cost_score)] <- 0

# Final site ranking score. Weights are retained from the original analysis.
candidate_patch_table$site_rank_score <- with(
  candidate_patch_table,
  0.275 * current_score +
    0.275 * stability_score +
    0.25 * wild_count_score +
    0.10 * cost_score +
    0.10 * area_score
)

candidate_patch_table <- candidate_patch_table %>%
  arrange(desc(site_rank_score))

# Rank classes are relative to the generated candidate set.
q50 <- quantile(candidate_patch_table$site_rank_score, 0.50, na.rm = TRUE)
q90 <- quantile(candidate_patch_table$site_rank_score, 0.90, na.rm = TRUE)

candidate_patch_table <- candidate_patch_table %>%
  mutate(
    rank_class = case_when(
      is.na(site_rank_score) ~ NA_character_,
      site_rank_score >= q90 ~ "High",
      site_rank_score < q50 ~ "Low",
      TRUE ~ "Medium"
    )
  )

candidate_patches <- add_rank_fields_to_patches(candidate_patches, candidate_patch_table)

# Quick diagnostic plots -------------------------------------------------------
plot(
