# Calculate local connectivity metrics for each candidate patch centroid.
calculate_candidate_connectivity <- function(candidate_pts, candidate_patches,
                                             patches, transition_layer,
                                             max_dist_m) {
  euclid_mat <- distance(candidate_pts, patches)
  cand_xy  <- crds(candidate_pts)
  patch_xy <- crds(patches)
  
  candidate_metrics <- vector("list", nrow(candidate_pts))
  
  for (i in seq_len(nrow(candidate_pts))) {
    nearby_idx <- which(euclid_mat[i, ] <= max_dist_m)
    
    if (length(nearby_idx) == 0) {
      candidate_metrics[[i]] <- data.frame(
        candidate_id = candidate_patches$candidate_id[i],
        n_nodes_200m = 0,
        n_wild_200m = 0,
        n_transloc_200m = 0,
        nearest_node_euclid_m = NA_real_,
        nearest_node_cost = NA_real_,
        mean_cost_to_nearby_nodes = NA_real_,
        min_cost_to_wild = NA_real_,
        mean_cost_to_wild = NA_real_
      )
      next
    }
    
    cost_vals <- rep(NA_real_, length(nearby_idx))
    
    for (k in seq_along(nearby_idx)) {
      j <- nearby_idx[k]
      
      d_ij <- try(
        costDistance(
          transition_layer,
          cand_xy[i, , drop = FALSE],
          patch_xy[j, , drop = FALSE]
        ),
        silent = TRUE
      )
      
      if (!inherits(d_ij, "try-error") && is.finite(d_ij[1, 1])) {
        cost_vals[k] <- d_ij[1, 1]
      }
    }
    
    nearby_types <- patches$node_type[nearby_idx]
    wild_costs   <- cost_vals[nearby_types == "wild"]
    
    candidate_metrics[[i]] <- data.frame(
      candidate_id = candidate_patches$candidate_id[i],
      n_nodes_200m = length(nearby_idx),
      n_wild_200m = sum(nearby_types == "wild"),
      n_transloc_200m = sum(nearby_types == "translocated"),
      nearest_node_euclid_m = min(euclid_mat[i, nearby_idx], na.rm = TRUE),
      nearest_node_cost = if (all(is.na(cost_vals))) NA_real_ else min(cost_vals, na.rm = TRUE),
      mean_cost_to_nearby_nodes = if (all(is.na(cost_vals))) NA_real_ else mean(cost_vals, na.rm = TRUE),
      min_cost_to_wild = if (length(wild_costs) == 0 || all(is.na(wild_costs))) NA_real_ else min(wild_costs, na.rm = TRUE),
      mean_cost_to_wild = if (length(wild_costs) == 0 || all(is.na(wild_costs))) NA_real_ else mean(wild_costs, na.rm = TRUE)
    )
  }
  
  do.call(rbind, candidate_metrics)
}

# Copy ranked table fields back onto the polygon object for writing/plotting.
add_rank_fields_to_patches <- function(candidate_patches, candidate_patch_table) {
  match_idx <- match(candidate_patches$candidate_id, candidate_patch_table$candidate_id)
  
  fields_to_copy <- c(
    "mean_current_suitability",
    "mean_climate_stability",
    "mean_priority",
    "area_m2",
    "area_ha",
    "n_nodes_200m",
    "n_wild_200m",
    "n_transloc_200m",
    "nearest_node_euclid_m",
    "nearest_node_cost",
    "mean_cost_to_nearby_nodes",
    "min_cost_to_wild",
    "mean_cost_to_wild",
    "site_rank_score",
    "rank_class"
  )
  
  for (field in fields_to_copy) {
    candidate_patches[[field]] <- candidate_patch_table[[field]][match_idx]
  }
  
  candidate_patches
}


